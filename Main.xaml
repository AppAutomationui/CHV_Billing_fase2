            <ui:InvokeCode ContinueOnError="{x:Null}" Code="' Inicializar la DataTable con las columnas requeridas&#xA;out_DataTable = New System.Data.DataTable()&#xA;out_DataTable.Columns.Add(&quot;Sociedad&quot;, GetType(String))&#xA;out_DataTable.Columns.Add(&quot;Tipo de Comprobante&quot;, GetType(String))&#xA;out_DataTable.Columns.Add(&quot;Tipo de proceso&quot;, GetType(String))&#xA;out_DataTable.Columns.Add(&quot;Pre-Billing&quot;, GetType(String))&#xA;out_DataTable.Columns.Add(&quot;Pedido&quot;, GetType(String))&#xA;&#xA;' Validar que el archivo exista antes de procesar&#xA;If System.IO.File.Exists(in_FilePath) Then&#xA;    ' Leer todas las líneas del archivo de texto&#xA;    Dim lines As String() = System.IO.File.ReadAllLines(in_FilePath)&#xA;    &#xA;    For Each line As String In lines&#xA;        ' Ignorar líneas vacías o espacios en blanco&#xA;        If Not String.IsNullOrWhiteSpace(line) Then&#xA;            ' Separar la línea usando el carácter Tabulador (vbTab)&#xA;            Dim parts As String() = line.Split(CChar(vbTab))&#xA;            &#xA;            ' Validar que la línea contenga al menos las 5 columnas esperadas&#xA;            If parts.Length &gt;= 5 Then&#xA;                out_DataTable.Rows.Add(&#xA;                    parts(0).Trim(), &#xA;                    parts(1).Trim(), &#xA;                    parts(2).Trim(), &#xA;                    parts(3).Trim(), &#xA;                    parts(4).Trim()&#xA;                )&#xA;            ElseIf parts.Length &gt; 0 Then&#xA;                ' En caso de que falte alguna columna al final, llena lo que encuentre&#xA;                Dim newRow As System.Data.DataRow = out_DataTable.NewRow()&#xA;                For i As Integer = 0 To Math.Min(parts.Length - 1, 4)&#xA;                    newRow(i) = parts(i).Trim()&#xA;                Next&#xA;                out_DataTable.Rows.Add(newRow)&#xA;            End If&#xA;        End If&#xA;    Next&#xA;Else&#xA;    Throw New System.IO.FileNotFoundException(&quot;No se encontró el archivo en la ruta especificada: &quot; &amp; in_FilePath)&#xA;End If" DisplayName="El archivo fase1 lo pasa a DT" sap:VirtualizedContainerService.HintSize="522,197" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
